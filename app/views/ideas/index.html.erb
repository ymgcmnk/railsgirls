<% if notice %>
  <p style="color: green"><%= notice %></p>
<% end %>



<% content_for :title, "Ideas" %>

<h1>Ideas</h1>

<p>There are currently <%= Idea.count %> active ideas</p>

<div class="mb-3">
  <%= link_to "New idea", new_idea_path, class: "btn btn-primary" %>
</div>

<div id="ideas">
  <% @ideas.order(id: :desc).each do |idea| %>
    <%= render idea %>
    <p>
      <%= link_to "Show this idea", idea %>
    </p>
  <% end %>
</div>


